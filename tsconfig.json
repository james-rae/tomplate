{
    "compilerOptions": {
        "rootDir": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@@/*": ["./*"]
        },
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "lib": ["ESNext", "DOM"],
        "moduleResolution": "bundler",
        "strict": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "noImplicitReturns": true,
        "forceConsistentCasingInFileNames": true,
        "types": ["vite/client", "node"]
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
